<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Disabled state -->
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_variant" />
            <stroke android:width="1dp" android:color="@color/border_light" />
            <corners android:radius="6dp" />
        </shape>
    </item>

    <!-- Focused state with primary color border -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/input_background" />
            <stroke android:width="2dp" android:color="@color/input_border_focused" />
            <corners android:radius="6dp" />
        </shape>
    </item>

    <!-- Normal state (default) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/input_background" />
            <stroke android:width="1dp" android:color="@color/input_border_default" />
            <corners android:radius="6dp" />
        </shape>
    </item>

</selector>